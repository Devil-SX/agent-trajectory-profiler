{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test:e2e": "playwright test --project=chromium --grep-invert @manual",
    "test:e2e:all": "playwright test --grep-invert @manual",
    "test:e2e:quick": "playwright test --grep @smoke --project=chromium",
    "test:e2e:smoke": "playwright test --grep @smoke --project=chromium",
    "test:e2e:smoke:shard": "sh -c 'playwright test --grep @smoke --project=chromium --shard=${PLAYWRIGHT_SHARD:-1/1}'",
    "test:e2e:full": "playwright test --grep @full --project=chromium",
    "test:e2e:full:shard": "sh -c 'playwright test --grep @full --project=chromium --shard=${PLAYWRIGHT_SHARD:-1/1}'",
    "test:e2e:visual": "playwright test --grep @visual --project=chromium",
    "test:e2e:a11y": "playwright test --grep @a11y --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:check-tags": "node ./scripts/validate-playwright-tags.mjs",
    "typegen": "node ./scripts/generate-api-types.mjs",
    "typegen:check": "node ./scripts/generate-api-types.mjs --check"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.20",
    "@types/react-syntax-highlighter": "^15.5.13",
    "lodash.debounce": "^4.0.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-window": "^2.2.6",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
